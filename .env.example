# GreenGrass Frontend Environment Variables
# Copy this file to .env and update the values

# API Configuration
# Backend API base URL
VITE_API_URL=http://[::1]:3000
# For production: VITE_API_URL=https://api.greengrass.vn

# API timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT=10000

# Application Settings
VITE_APP_NAME=GreenGrass
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Feature Flags (optional)
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_LEADERBOARD=true
VITE_FEATURE_GAMIFICATION=true

# Analytics (optional - set to false in development)
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_KEY=

# Debug Mode (set to true for verbose logging)
VITE_DEBUG=false

# Auth Configuration
VITE_TOKEN_STORAGE=localStorage
# Future improvement: use VITE_TOKEN_STORAGE=cookie for HttpOnly cookies

